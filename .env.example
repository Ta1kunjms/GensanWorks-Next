# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/database

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
# Optional legacy alias consumed by middleware/auth fallback
AUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# External Services
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@your-domain.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
NOTIFICATION_EMAIL_ENABLED=1
NOTIFICATION_SMS_ENABLED=0

# AI & Analytics
GROQ_API_KEY=your-groq-api-key
NEXT_PUBLIC_POSTHOG_API_KEY=your-posthog-key
MATCHING_BATCH_SIZE=3
MATCHING_BATCH_DELAY_MS=500
MATCHING_SCORE_VERSION=1.0.0
MATCHING_SEMANTIC_CONFIDENCE_THRESHOLD=0.75
MATCHING_QPE_YEARS_THRESHOLD=5
MATCHING_DISPARITY_MIN_GROUP_SIZE=3
MATCHING_DISPARITY_DEVIATION_THRESHOLD=0.15

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_MATCHING=true
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_PWA=true

# Application Settings
NEXT_PUBLIC_APP_NAME=GensanWorks
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STATUS_PAGE_URL=https://status.your-domain.com
STATUS_PAGE_URL=https://status.your-domain.com
NODE_ENV=development

# Optional: account deletion processor automation
ACCOUNT_DELETION_CRON_SECRET=set-a-strong-random-secret
